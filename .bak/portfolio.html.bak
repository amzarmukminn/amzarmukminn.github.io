                    </figcaption>
                  </figure>
                </td>

                <!-- Project details -->
                <td>
                  <font face="Arial" size="2">
                    <p><b>Description:</b><br />
                    A personal resume website built entirely with HTML5 for the
                    <abbr title="IMS 458 Web Design and Development">IMS 458</abbr> assignment.
                    The site showcases my academic background, skills, co-curricular
                    activities, and portfolio across 5 linked pages.</p>

                    <p><b>Tools used:</b> Notepad, Adobe Photoshop, HTML5</p>

                    <p><b>Year:</b> <time datetime="2026">2026</time></p>

                    <p>
                      <b>Live site:</b>
                      <a href="http://yourname.free.nf" target="_blank">yourname.free.nf</a>
                    </p>
