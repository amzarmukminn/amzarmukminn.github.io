            <!-- ======== PROJECT 2 ======== -->
            <h2><a name="project2"></a><font face="Arial" color="#003322">Project 2 &mdash; Cyber Security Info Page</font></h2>

            <table border="1"
                   width="100%"
                   cellspacing="5"
                   cellpadding="12"
